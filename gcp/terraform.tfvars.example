###############################################################################
# Example tfvars for the GCP migration module.
#
# Copy to terraform.tfvars and fill in real values. terraform.tfvars is
# gitignored; this *.tfvars.example file is the only one committed.
#
# Vault address + token and the parent SA JSON are easiest to supply via
# environment variables:
#
#   export TF_VAR_vault_address="$VAULT_ADDR"
#   export TF_VAR_vault_token="$VAULT_TOKEN"
#   export TF_VAR_parent_sa_credentials="$(cat ./parent-sa.json)"
#
# (terraform.tfvars only accepts literal values; the file() function is not
# supported there, so load the JSON via the env var or the -var flag.)
###############################################################################

# ------------------------------------------------------------------
# Vault
# ------------------------------------------------------------------
# vault_address = "https://vault.example.com"   # or set TF_VAR_vault_address
# vault_token   = "hvs.xxxxx"                   # or set TF_VAR_vault_token (sensitive)

# Optional allowlist of Vault GCP mount paths to migrate. Empty (default)
# means every type=="gcp" mount from sys/mounts is in scope. Use this on
# shared Vault servers where some mounts belong to other teams. Trailing
# slash is optional.
# vault_mount_paths = [
#   "prod/app-1234-saas/gcp/",
#   "stage/app-1234-saas/gcp/",
# ]

# ------------------------------------------------------------------
# Akeyless
# ------------------------------------------------------------------
akeyless_access_id    = "p-xxxxxxxxxxxx"
akeyless_gcp_audience = "akeyless.io"

# Your gateway's V2 SDK URL, NOT https://api.akeyless.io. Public api does not
# expose dynamic-secret-create-gcp; only customer gateways do. Two valid forms:
#   - Direct SDK port (gateway exposed on its native :8081 or a port-forward):
#     append "/v2", e.g.
#       https://gateway.example.com:8081/v2
#       http://127.0.0.1:8081/v2
#   - Ingress-fronted gateway (nginx, Istio) on a path-based route: append
#     "/api/v2", e.g.
#       https://gateway.example.com/api/v2
# Verify by hitting a real V2 POST endpoint such as static-creds-auth:
#   curl -sS -o /dev/null -w '%{http_code}\n' -X POST "${URL}/static-creds-auth"
# Expect HTTP 400 (the endpoint requires a body; the 400 only proves the URL
# is correct). 404 with text/plain `404 page not found` means the ingress
# rejected the path: flip between /v2 and /api/v2 and retry. 404 with
# application/json `{"error":"unknown command 'X'"}` means the URL prefix is
# correct but the test endpoint name is wrong: pick another known endpoint.
akeyless_gateway_url = "https://your-gateway.example.com:8081/v2"

akeyless_target_name = "migrated-from-vault-gcp"

# ------------------------------------------------------------------
# Parent SA credentials
# ------------------------------------------------------------------
# Raw JSON content of the parent SA key. The module base64-encodes it before
# sending to Akeyless. Easiest is the env var pattern shown above; if you
# really want it in tfvars, paste the raw JSON as a heredoc string.
# parent_sa_credentials = "<raw JSON content>"

# ------------------------------------------------------------------
# Roleset overrides (REQUIRED if any rolesets are discovered in Vault)
# ------------------------------------------------------------------
# One pre-existing service-account email per Vault roleset. Keys are
# `<env>/<app>/<roleset_name>` because roleset names can collide across apps.
# The `<roleset_name>` is the literal Vault entity name and may itself end in
# `-app` for the Kubernetes runtime variant of a logical secret. See
# gcp/runbooks/05-roleset-durable-sa.md for the rationale and the bindings
# these SAs need. The plan fails with a precondition error if a discovered
# roleset has no entry here.
roleset_sa_overrides = {
  # "prod/app-1234-saas/dyn-secret1"     = "dyn-secret1@<project>.iam.gserviceaccount.com"
  # "prod/app-1234-saas/dyn-secret1-app" = "dyn-secret1-app@<project>.iam.gserviceaccount.com"
}
